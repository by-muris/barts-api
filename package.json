{
  "name": "@by-muris/barts-api",
  "version": "0.1.0",
  "description": "A small Express API framework with OpenAPI generation and dependency injection",
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json --resolve-full-paths --resolve-full-extension .js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "prepack": "npm run build",
    "prepare": "node scripts/prepare-husky.mjs",
    "typecheck": "tsc --noEmit",
    "pack:dry-run": "npm pack --dry-run"
  },
  "peerDependencies": {
    "class-transformer": "^0.5.0",
    "class-validator": "^0.14.0",
    "express": "^4.21.0 || ^5.0.0",
    "reflect-metadata": "^0.1.13 || ^0.2.0"
  },
  "dependencies": {
    "class-validator-jsonschema": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.13.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.4",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "express": "^5.1.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "reflect-metadata": "^0.2.2",
    "tsc-alias": "^1.8.16",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.44.1"
  }
}
